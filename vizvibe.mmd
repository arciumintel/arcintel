    style cloudinary_upload fill:#1a1a2e,stroke:#a78bfa,color:#c4b5fd,stroke-width:1px
    style decision_waterfall fill:#1a1a2e,stroke:#64748b,color:#94a3b8,stroke-width:1px
    style decision_staff_only fill:#1a1a2e,stroke:#64748b,color:#94a3b8,stroke-width:1px
    style decision_immutable fill:#1a1a2e,stroke:#64748b,color:#94a3b8,stroke-width:1px

